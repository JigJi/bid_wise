# Postgres (shared instance, project-specific DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bid_wise

# bid_wise services (project-specific ports — see CLAUDE.md known-ports list)
APP_PORT=8200
APP_ENV=dev

# Chrome CDP for Playwright e-GP scraping
CDP_PORT=9231
CHROME_PROFILE_DIR=chrome_profile

# LLM via OpenRouter (single key, multi-provider gateway)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model strategy:
#  - extraction (1-shot per project, structured JSON, quality matters): Claude Sonnet
#  - q&a (high volume, lower cost OK): gpt-4o-mini
LLM_MODEL_EXTRACTION=anthropic/claude-sonnet-4.5
LLM_MODEL_QA=openai/gpt-4o-mini
LLM_HTTP_REFERER=https://bidwise.local
LLM_APP_TITLE=bid_wise
